generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model YamlConfig {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  study_name    String @default("")
  alias         String @default("")
  url           String @default("")
  created       DateTime @default("1970-01-01T00:00:00.000Z")
  last_modified DateTime @default("1970-01-01T00:00:00.000Z")
  version       Int @default(0)

  provenance_source                         String @default("")
  provenance_source_access_or_creation_date DateTime @default("1970-01-01T00:00:00.000Z")
}