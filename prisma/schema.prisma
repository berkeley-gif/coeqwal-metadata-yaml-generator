generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model YamlConfig {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  
  study_name    String @default("")
  alias         String @default("")
  url           String @default("")
  created       DateTime @default("1970-01-01T00:00:00.000Z")
  last_modified DateTime @default("1970-01-01T00:00:00.000Z")
  version       String @default("")

  provenance_baseline_source                         String @default("")
  provenance_source_access_date                      DateTime @default("1970-01-01T00:00:00.000Z")

  dependencies   Dependency[]
  assumptions    YamlConfigAssumption[]
}

model Dependency {
  id            String   @id @default(uuid())
  name          String @default("")

  YamlConfig YamlConfig[]
}

model YamlConfigAssumption {
  id            String   @id @default(uuid())
  name          String @default("")
  kindId        String
  source        String @default("")
  source_access_date DateTime @default("1970-01-01T00:00:00.000Z")
  version       String @default("")
  description   String @default("")
  file          String @default("")
  
  kind          AssumptionKind @relation(fields: [kindId], references: [id])

  YamlConfig YamlConfig[]
}

model AssumptionKind {
  id            String   @id @default(uuid())
  name          String @default("")

  YamlConfigAssumption YamlConfigAssumption[]
}